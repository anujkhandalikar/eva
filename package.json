{
  "name": "tmp-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n next,inngest,whatsapp,blinkit -c blue,magenta,green,yellow \"npm:dev:next\" \"npm:dev:inngest\" \"npm:dev:whatsapp\" \"npm:dev:blinkit\"",
    "dev:core": "concurrently -k -n next,inngest -c blue,magenta \"npm:dev:next\" \"npm:dev:inngest\"",
    "dev:next": "next dev",
    "dev:inngest": "npx --yes inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "dev:whatsapp": "cd \"$HOME/tools/whatsapp-mcp/whatsapp-bridge\" && ./whatsapp-bridge",
    "dev:blinkit": "cd \"$HOME/blinkit-mcp\" && SERVE_HTTPS=true ./start.sh",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.105.3",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "cron-parser": "^5.5.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "inngest": "^4.2.6",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "node-cron": "^4.2.1",
    "openai": "^6.36.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
